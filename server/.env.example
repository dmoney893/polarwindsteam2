# Server Environment Variables
# Copy this file to .env for local development:
#   cp server/.env.example server/.env
# Everything below is optional for local play — the defaults work out of the box.

# Server port (your host may set this automatically in production)
PORT=2567

# Environment
NODE_ENV=development

# CORS allowed origin (set to your client URL in production)
CLIENT_URL=http://localhost:8080

# --- Voice/video chat (LiveKit) — optional ---
# The game runs without these; you just won't have in-game voice/video.
# Get free credentials at https://cloud.livekit.io/
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
